import { useQuery, useMutation, useQueryClient } from "@tanstack/react-query";

export function useResources() {
  return useQuery({ queryKey: ["resources"], queryFn: () => fetch("/api/v1/resources").then(r => r.json()) });
}

export function useCreateResource() {
  const qc = useQueryClient();
  return useMutation({
    mutationFn: (data: unknown) => fetch("/api/v1/resources", { method: "POST", body: JSON.stringify(data), headers: { "Content-Type": "application/json" } }).then(r => r.json()),
    onSuccess: () => qc.invalidateQueries({ queryKey: ["resources"] }),
  });
}
