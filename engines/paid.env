# Citadel SaaS Factory — Paid Engine (Anthropic direct)
#
# Source this file before launching Claude Code to route through
# Anthropic's production API with full Claude 4.6 quality.
#
# Usage:
#   source engines/paid.env && claude
#   # or:
#   make run-paid

# Required: your Anthropic API key
# Get one at: https://console.anthropic.com/settings/keys
export ANTHROPIC_API_KEY="sk-ant-PLACEHOLDER"

# Primary model — use the latest Claude 4.6 Sonnet for coding work
export ANTHROPIC_MODEL="claude-sonnet-4-6"

# Small/fast model — used for classification, routing, and simple tool calls
export ANTHROPIC_SMALL_FAST_MODEL="claude-haiku-4-5-20251001"

# No BASE_URL override — traffic goes directly to api.anthropic.com
unset ANTHROPIC_BASE_URL
unset ANTHROPIC_AUTH_TOKEN

# Telemetry
export CITADEL_ENGINE="paid"
export CITADEL_ENGINE_PROVIDER="anthropic"

echo "[citadel] engine=paid provider=anthropic model=$ANTHROPIC_MODEL"
