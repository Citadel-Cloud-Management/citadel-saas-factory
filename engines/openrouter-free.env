# Citadel SaaS Factory — OpenRouter Free Engine
#
# Routes Claude Code traffic through OpenRouter's free tier.
# Cost: $0/month (rate-limited). Quality: ~80% of Sonnet on coding tasks.
#
# Usage:
#   source engines/openrouter-free.env && claude
#   # or:
#   make run-free
#
# Requires: a free OpenRouter account + API key at https://openrouter.ai/keys

# Route all Claude Code API calls through OpenRouter
export ANTHROPIC_BASE_URL="https://openrouter.ai/api"

# OpenRouter uses the AUTH_TOKEN variable, not API_KEY
export ANTHROPIC_AUTH_TOKEN="sk-or-PLACEHOLDER"
unset ANTHROPIC_API_KEY

# Primary model — Llama 3.3 70B is the strongest free coding model as of 2026
export ANTHROPIC_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# Small/fast model — Qwen 3 8B is fast and free
export ANTHROPIC_SMALL_FAST_MODEL="qwen/qwen3-8b:free"

# Other working free models (uncomment to swap):
#   google/gemma-3-27b-it:free          — Google's free Gemma 3, strong on reasoning
#   mistralai/mistral-7b-instruct:free  — Mistral 7B, low latency
#   deepseek/deepseek-r1:free           — DeepSeek R1 for complex reasoning
#   qwen/qwen-2.5-coder-32b-instruct:free — Qwen 2.5 Coder 32B, best for code

# Telemetry
export CITADEL_ENGINE="free"
export CITADEL_ENGINE_PROVIDER="openrouter"

echo "[citadel] engine=free provider=openrouter model=$ANTHROPIC_MODEL"
echo "[citadel] rate-limited free tier — expect occasional 429s"
