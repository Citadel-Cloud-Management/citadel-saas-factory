# Citadel SaaS Factory — Local Ollama Engine
#
# Runs Claude Code fully offline against a local Ollama / vLLM server,
# proxied through y-router (or LiteLLM) to translate OpenAI-style
# responses into the Anthropic Messages API format.
#
# Cost: $0/month, zero data egress, zero rate limits.
# Quality: depends on local model; qwen2.5-coder:32b ~= GPT-4o-mini.
#
# Usage:
#   source engines/local-ollama.env && claude
#   # or:
#   make run-local
#
# Prerequisites:
#   1. Install Ollama:            https://ollama.com/download
#   2. Pull coding models:        ollama pull qwen2.5-coder:32b
#                                 ollama pull qwen2.5-coder:7b
#   3. Install y-router:          npm install -g @musistudio/y-router
#   4. Start y-router on :8787:   y-router --upstream http://localhost:11434 --port 8787
#      (or use docker-compose up -d if you have the local-stack compose file)

# Route through the local Anthropic-compatible proxy
export ANTHROPIC_BASE_URL="http://localhost:8787"

# y-router ignores the token but Claude Code requires a non-empty value
export ANTHROPIC_AUTH_TOKEN="ollama"
unset ANTHROPIC_API_KEY

# Primary model — Qwen 2.5 Coder 32B is the best local coding model as of 2026
export ANTHROPIC_MODEL="qwen2.5-coder:latest"

# Small/fast model — reuse the same family at 7B for faster responses
export ANTHROPIC_SMALL_FAST_MODEL="qwen2.5-coder:7b"

# Telemetry
export CITADEL_ENGINE="local"
export CITADEL_ENGINE_PROVIDER="ollama"

echo "[citadel] engine=local provider=ollama model=$ANTHROPIC_MODEL"
echo "[citadel] ensure y-router is running: y-router --port 8787"
