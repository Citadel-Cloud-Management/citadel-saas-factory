# Citadel SaaS Factory — Environment Configuration (AWS)
# Copy this file: cp .env.example .env
# NEVER commit .env to git

# ─── Required Tokens ───
ANTHROPIC_API_KEY=sk-ant-your-key-here
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# ─── Application ───
APP_NAME=citadel-fintech-saas
APP_ENV=development
APP_VERSION=3.1.0
APP_PORT=8000
FRONTEND_PORT=3000
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── AWS Configuration ───
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_DEPLOY_ROLE_ARN=arn:aws:iam::123456789012:role/citadel-deploy
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
EKS_CLUSTER_STAGING=citadel-staging-eks
EKS_CLUSTER_PRODUCTION=citadel-production-eks

# ─── Database (Aurora PostgreSQL Serverless v2) ───
DATABASE_URL=postgresql://citadel_admin:CHANGE_ME@citadel-production.cluster-xxx.us-east-1.rds.amazonaws.com:5432/citadel
POSTGRES_USER=citadel_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=citadel

# ─── Redis (ElastiCache) ───
REDIS_URL=rediss://:CHANGE_ME@citadel-production.xxx.use1.cache.amazonaws.com:6379/0
REDIS_PASSWORD=CHANGE_ME

# ─── Keycloak (EKS-hosted) ───
KEYCLOAK_URL=https://auth.citadelcloudmanagement.com
KEYCLOAK_REALM=citadel
KEYCLOAK_CLIENT_ID=citadel-app
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
JWKS_URL=https://auth.citadelcloudmanagement.com/realms/citadel/protocol/openid-connect/certs

# ─── S3 Object Storage ───
AWS_S3_BUCKET=citadel-production-assets
AWS_S3_REGION=us-east-1

# ─── Stripe (Billing) ───
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_STARTER=price_CHANGE_ME
STRIPE_PRICE_PRO=price_CHANGE_ME
STRIPE_PRICE_ENTERPRISE=price_CHANGE_ME

# ─── KYC/AML Provider ───
SUMSUB_APP_TOKEN=CHANGE_ME
SUMSUB_SECRET_KEY=CHANGE_ME
SUMSUB_WEBHOOK_SECRET=CHANGE_ME

# ─── Payment Providers ───
PLAID_CLIENT_ID=CHANGE_ME
PLAID_SECRET=CHANGE_ME
PLAID_ENV=sandbox
WISE_API_KEY=CHANGE_ME

# ─── CORS ───
CORS_ORIGINS=https://app.citadelcloudmanagement.com,https://api.citadelcloudmanagement.com

# ─── Monitoring ───
PROMETHEUS_URL=http://prometheus.monitoring.svc.cluster.local:9090
GRAFANA_URL=https://monitoring.citadelcloudmanagement.com
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.monitoring.svc.cluster.local:4317

# ─── Slack Notifications ───
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME

# ─── AI Model Routing ───
CITADEL_ENGINE=paid
CITADEL_ENGINE_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENROUTER_API_KEY=CHANGE_ME

# ─── Agentic Autonomy Level ───
# L1=interactive, L2=delegation, L3=human_orchestration, L4=system_orchestration, L5=full_autonomy
AGENTIC_LEVEL=L3
AGENT_AUTO_DEPLOY=false
AGENT_AUTO_REMEDIATE=true
AGENT_AUTO_SCALE=true
AGENT_BUDGET_DAILY_USD=50
