# Citadel SaaS Factory — Environment Configuration
# Copy this file: cp .env.example .env
# NEVER commit .env to git

# ─── Required ───
ANTHROPIC_API_KEY=sk-ant-your-key-here
GITHUB_TOKEN=ghp_your_token_here

# ─── Application ───
APP_NAME=citadel-saas-factory
APP_ENV=development
APP_PORT=8000
FRONTEND_PORT=3000
SECRET_KEY=change-me-in-production

# ─── Database ───
DATABASE_URL=postgresql://citadel:citadel@localhost:5432/citadel
POSTGRES_USER=citadel
POSTGRES_PASSWORD=citadel
POSTGRES_DB=citadel

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── Keycloak ───
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=citadel
KEYCLOAK_CLIENT_ID=citadel-app
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── MinIO (S3-compatible storage) ───
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000

# ─── RabbitMQ ───
RABBITMQ_DEFAULT_USER=citadel
RABBITMQ_DEFAULT_PASS=citadel
RABBITMQ_URL=amqp://citadel:citadel@localhost:5672

# ─── Monitoring ───
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001

# ─── Optional: Vault ───
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=your-vault-token

# ─── Optional: Kubernetes ───
# KUBECONFIG=~/.kube/config
