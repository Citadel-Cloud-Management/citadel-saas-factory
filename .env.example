# Citadel SaaS Factory — Environment Configuration
# Copy this file: cp .env.example .env
# NEVER commit .env to git

# ─── Required Tokens ───
ANTHROPIC_API_KEY=sk-ant-your-key-here
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# ─── Application ───
APP_NAME=citadel-saas-factory
APP_ENV=development
APP_VERSION=3.0.0
APP_PORT=8000
FRONTEND_PORT=3000
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Database ───
DATABASE_URL=postgresql://citadel:citadel@localhost:5432/citadel
POSTGRES_USER=citadel
POSTGRES_PASSWORD=citadel
POSTGRES_DB=citadel

# ─── Redis ───
REDIS_PASSWORD=citadel_redis
REDIS_URL=redis://:citadel_redis@localhost:6379/0

# ─── Keycloak ───
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=citadel
KEYCLOAK_CLIENT_ID=citadel-app
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
JWKS_URL=http://localhost:8080/realms/citadel/protocol/openid-connect/certs

# ─── MinIO (S3-compatible storage) ───
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=citadel

# ─── RabbitMQ ───
RABBITMQ_DEFAULT_USER=citadel
RABBITMQ_DEFAULT_PASS=citadel
RABBITMQ_URL=amqp://citadel:citadel@localhost:5672

# ─── CORS ───
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Monitoring ───
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── Optional: Vault ───
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=your-vault-token

# ─── Optional: Kubernetes ───
# KUBECONFIG=~/.kube/config
